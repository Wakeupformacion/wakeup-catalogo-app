<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Panel admin · WakeUp</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <%- include('partials-header') %>
    <main class="page admin-page">
      <section class="admin-topbar">
        <div>
          <p class="eyebrow dark">Administración</p>
          <h1>Mantenimiento del catálogo</h1>
          <p class="helper-text">Estado: <strong><%= usingDemoData ? 'modo fallback' : 'base de datos' %></strong></p>
        </div>
        <form method="post" action="/admin/logout">
          <button class="button ghost" type="submit">Salir</button>
        </form>
      </section>

      <% if (flash) { %>
        <p class="admin-success"><%= flash %></p>
      <% } %>
      <% if (error) { %>
        <p class="admin-error"><%= error %></p>
      <% } %>

      <section class="admin-grid">
        <article class="card admin-panel">
          <div class="admin-panel-heading">
            <h2>Nuevo curso</h2>
          </div>
          <form method="post" action="/admin/courses" class="admin-form-grid">
            <label><span>Código</span><input type="text" name="course_code" required /></label>
            <label><span>Título</span><input type="text" name="title" required /></label>
            <label><span>Categoría</span><input type="text" name="category_raw" required /></label>
            <label><span>Horas</span><input type="number" name="hours" min="1" /></label>
            <label><span>Modalidad</span><input type="text" name="delivery_mode" value="online" /></label>
            <label><span>URL detalle</span><input type="url" name="detail_url" /></label>
            <label class="checkbox-label"><input type="checkbox" name="is_active" checked /> <span>Activo</span></label>
            <div class="admin-actions-row"><button type="submit">Crear curso</button></div>
          </form>
        </article>

        <article class="card admin-panel">
          <div class="admin-panel-heading">
            <h2>Carga de Excel/CSV</h2>
            <p class="helper-text">Acepta CSV delimitado por comas o punto y coma y también ficheros Excel `.xlsx`.</p>
          </div>
          <form method="post" action="/admin/import" enctype="multipart/form-data" class="admin-form-stack">
            <label><span>Fichero</span><input type="file" name="catalogFile" accept=".csv,.txt,.xlsx" required /></label>
            <button type="submit">Cargar catálogo</button>
          </form>
          <div class="admin-note-box">
            <strong>Columnas recomendadas</strong>
            <p><code>course_code</code>, <code>title</code>, <code>category_raw</code>, <code>hours</code>, <code>delivery_mode</code>, <code>detail_url</code>, <code>is_active</code></p>
          </div>
        </article>
      </section>

      <section class="card admin-panel">
        <div class="admin-list-header">
          <div>
            <h2>Cursos</h2>
            <p class="helper-text"><%= courses.length %> cursos cargados</p>
          </div>
          <input type="search" id="adminCourseFilter" class="admin-search-input" placeholder="Filtrar por código, título o categoría..." />
        </div>

        <div class="admin-cards-list" id="adminCourseList">
          <% courses.forEach(function(course) { %>
            <article class="admin-course-card" data-search="<%= [course.course_code, course.title, course.category_raw].filter(Boolean).join(' ').toLowerCase() %>">
              <div class="admin-course-head">
                <div>
                  <p class="admin-course-code"><%= course.course_code %></p>
                  <h3><%= course.title %></h3>
                  <p class="admin-course-meta"><%= course.category_raw || 'Sin categoría' %> · <%= course.hours || '-' %> horas · <%= course.delivery_mode || 'online' %></p>
                </div>
                <span class="admin-status-pill <%= course.is_active !== false ? 'is-active' : 'is-inactive' %>">
                  <%= course.is_active !== false ? 'Activo' : 'Inactivo' %>
                </span>
              </div>

              <form method="post" action="/admin/courses/<%= course.slug %>" class="admin-form-grid admin-edit-form">
                <label><span>Código</span><input type="text" name="course_code" value="<%= course.course_code %>" required /></label>
                <label><span>Título</span><input type="text" name="title" value="<%= course.title %>" required /></label>
                <label><span>Categoría</span><input type="text" name="category_raw" value="<%= course.category_raw || '' %>" required /></label>
                <label><span>Horas</span><input type="number" name="hours" min="1" value="<%= course.hours || '' %>" /></label>
                <label><span>Modalidad</span><input type="text" name="delivery_mode" value="<%= course.delivery_mode || 'online' %>" /></label>
                <label><span>URL detalle</span><input type="url" name="detail_url" value="<%= course.detail_url || '' %>" placeholder="URL detalle" /></label>
                <label class="checkbox-label"><input type="checkbox" name="is_active" <%= course.is_active !== false ? 'checked' : '' %> /> <span>Activo</span></label>
                <div class="admin-inline-actions admin-actions-row">
                  <button type="submit">Guardar cambios</button>
              </form>
                  <form method="post" action="/admin/courses/<%= course.slug %>/delete" onsubmit="return confirm('¿Eliminar este curso?');">
                    <button type="submit" class="button ghost">Eliminar</button>
                  </form>
                </div>
            </article>
          <% }) %>
        </div>
      </section>
    </main>

    <script>
      (function () {
        const input = document.getElementById('adminCourseFilter');
        const items = Array.from(document.querySelectorAll('#adminCourseList .admin-course-card'));
        if (!input || !items.length) return;
        input.addEventListener('input', function () {
          const q = String(input.value || '').trim().toLowerCase();
          items.forEach(function (item) {
            const haystack = item.getAttribute('data-search') || '';
            item.style.display = !q || haystack.includes(q) ? '' : 'none';
          });
        });
      })();
    </script>
  </body>
</html>
