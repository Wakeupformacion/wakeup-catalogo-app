<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%- include('partials-meta') %>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <%- include('partials-header') %>
    <main class="page">
      <header class="page-header">
        <a href="/" class="back-link">← Inicio</a>
        <h1>Catálogo de cursos online</h1>
        <p>Busca por temática, duración o necesidad formativa.</p>
      </header>

      <form class="filters" action="/cursos" method="get">
        <% (selectedCourses || []).forEach(function(slug) { %>
          <input type="hidden" name="courses" value="<%= slug %>" />
        <% }) %>
        <input type="text" name="q" value="<%= q %>" placeholder="Busca cursos o escribe tu necesidad formativa..." />
        <select name="category" class="category-select">
          <option value="">Todas las categorías</option>
          <% (allCategories || []).forEach(function(item) { %>
            <option value="<%= item.category_normalized %>" <%= item.category_normalized === category ? 'selected' : '' %>>
              <%= item.category_label %> (<%= item.total %>)
            </option>
          <% }) %>
        </select>
        <input type="number" name="maxHours" value="<%= maxHours || '' %>" placeholder="Máx. horas" min="1" />
        <button type="submit">Filtrar</button>
        <% if (q || category || maxHours) { %>
          <a class="button ghost" href="/cursos">Limpiar filtros</a>
        <% } %>
      </form>
      <% if (catalogMicrocopy && catalogMicrocopy.searchHint) { %>
        <p class="helper-text"><%= catalogMicrocopy.searchHint %></p>
      <% } %>

      <% const activeCategoryChip = (categoryChips || []).find(function(item) { return item.category_normalized === category; }); %>
      <% if (q || category || maxHours) { %>
        <section class="active-filters-row">
          <span class="active-filters-label">Filtros activos:</span>
          <% if (q) { %>
            <span class="chip active-filter-chip">Búsqueda: <strong><%= q %></strong></span>
          <% } %>
          <% if (category) { %>
            <span class="chip active-filter-chip">Categoría: <strong><%= activeCategoryChip ? activeCategoryChip.category_label : category %></strong></span>
          <% } %>
          <% if (maxHours) { %>
            <span class="chip active-filter-chip">Máx. <strong><%= maxHours %></strong> horas</span>
          <% } %>
        </section>
      <% } %>

      <section class="results-meta">
        <p><strong><%= items.length %></strong> cursos mostrados</p>
        <% if (q) { %>
          <p>Resultado para: <strong><%= q %></strong></p>
        <% } else if (category) { %>
          <p>Explorando cursos dentro de la categoría seleccionada.</p>
        <% } else { %>
          <p>Explora el catálogo completo.</p>
        <% } %>
      </section>

      <% if (!items.length) { %>
        <section class="empty-state">
          <h2>No hemos encontrado cursos exactos</h2>
          <p>Prueba con una búsqueda más amplia, otra categoría o elimina el límite de horas.</p>
          <% if (emptyStateTips && emptyStateTips.length) { %>
            <ul>
              <% emptyStateTips.forEach(function(item) { %>
                <li><%= item %></li>
              <% }) %>
            </ul>
          <% } %>
        </section>
      <% } %>

      <% if (items.length) { %>
        <form class="budget-builder" id="budget-builder" action="/presupuesto" method="get">
          <section class="budget-toolbar" aria-live="polite">
            <div>
              <p class="budget-toolbar-label">Selección para presupuesto</p>
              <p class="budget-toolbar-text"><span id="selected-count">0</span> cursos seleccionados</p>
            </div>
            <div class="budget-toolbar-actions">
              <button type="button" class="button ghost" id="clear-selection" disabled>Vaciar selección</button>
              <button type="submit" class="button" id="budget-submit" disabled>Generar presupuesto</button>
            </div>
          </section>

          <section class="selection-tray" id="selection-tray" hidden>
            <div class="selection-tray-head">
              <div>
                <p class="budget-toolbar-label">Cursos añadidos</p>
                <p class="selection-tray-text">Mantendremos esta selección aunque cambies la búsqueda o el área.</p>
              </div>
              <span class="chip"><span id="selection-tray-count">0</span> guardados</span>
            </div>
            <div class="selection-tray-list" id="selection-tray-list"></div>
          </section>

          <section class="cards selectable-cards">
            <% items.forEach(function(course) { %>
              <article class="card selectable-card" data-course-card>
                <label class="course-select-label">
                  <input type="checkbox" name="courses" value="<%= course.slug %>" data-course-checkbox data-course-title="<%= course.title %>" <%= (selectedCourses || []).includes(course.slug) ? 'checked' : '' %> />
                  <span>Seleccionar curso</span>
                </label>
                <div class="card-body">
                  <p class="card-category"><%= course.category_raw || 'Sin categoría' %></p>
                  <div class="card-title-row">
                    <h2><%= course.title %></h2>
                    <% if (course.detail_url) { %>
                      <a class="button card-inline-button" href="<%= course.detail_url %>" target="_blank" rel="noopener noreferrer">Ver contenidos y objetivos</a>
                    <% } %>
                  </div>
                  <ul class="meta">
                    <li><strong>Horas:</strong> <%= course.hours || '-' %></li>
                    <li><strong>Modalidad:</strong> <%= course.delivery_mode %></li>
                  </ul>
                </div>
              </article>
            <% }) %>
          </section>
        </form>

        <script>
          (function () {
            const form = document.getElementById('budget-builder');
            if (!form) return;

            const STORAGE_KEY = 'wakeup-selected-courses';
            const checkboxes = Array.from(form.querySelectorAll('[data-course-checkbox]'));
            const filterForm = document.querySelector('form.filters');
            const selectedCount = document.getElementById('selected-count');
            const selectionTray = document.getElementById('selection-tray');
            const selectionTrayCount = document.getElementById('selection-tray-count');
            const selectionTrayList = document.getElementById('selection-tray-list');
            const submitButton = document.getElementById('budget-submit');
            const clearButton = document.getElementById('clear-selection');

            function readStored() {
              try {
                return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
              } catch (_error) {
                return [];
              }
            }

            function writeStored(items) {
              localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
            }

            function syncFilterHiddenInputs(selected) {
              if (!filterForm) return;
              filterForm.querySelectorAll('input[data-selected-course-hidden]').forEach((node) => node.remove());
              selected.forEach((item) => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'courses';
                input.value = item.slug;
                input.setAttribute('data-selected-course-hidden', 'true');
                filterForm.appendChild(input);
              });
            }

            function syncBudgetHiddenInputs(selected) {
              form.querySelectorAll('input[data-selected-course-hidden]').forEach((node) => node.remove());
              selected.forEach((item) => {
                if (checkboxes.some((checkbox) => checkbox.value === item.slug)) return;
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'courses';
                input.value = item.slug;
                input.setAttribute('data-selected-course-hidden', 'true');
                form.appendChild(input);
              });
            }

            function buildSelectedState() {
              const stored = readStored();
              const bySlug = new Map(stored.map((item) => [item.slug, item]));

              checkboxes.forEach((checkbox) => {
                if (checkbox.checked) {
                  bySlug.set(checkbox.value, {
                    slug: checkbox.value,
                    title: checkbox.dataset.courseTitle || checkbox.value,
                  });
                } else if (bySlug.has(checkbox.value)) {
                  const stillHidden = form.querySelector(`input[data-selected-course-hidden][value="${checkbox.value}"]`);
                  if (!stillHidden) bySlug.delete(checkbox.value);
                }
              });

              return Array.from(bySlug.values());
            }

            function applyStoredSelection() {
              const stored = readStored();
              checkboxes.forEach((checkbox) => {
                checkbox.checked = stored.some((item) => item.slug === checkbox.value);
              });
            }

            function updateSelectionState() {
              const selected = buildSelectedState();
              writeStored(selected);
              syncFilterHiddenInputs(selected);
              syncBudgetHiddenInputs(selected);

              selectedCount.textContent = String(selected.length);
              submitButton.disabled = selected.length === 0;
              clearButton.disabled = selected.length === 0;
              selectionTray.hidden = selected.length === 0;
              selectionTrayCount.textContent = String(selected.length);
              selectionTrayList.innerHTML = '';

              checkboxes.forEach((checkbox) => {
                const card = checkbox.closest('[data-course-card]');
                if (!card) return;
                card.classList.toggle('is-selected', checkbox.checked);
              });

              selected.forEach((item) => {
                const trayItem = document.createElement('button');
                trayItem.type = 'button';
                trayItem.className = 'selection-pill';
                trayItem.textContent = item.title || item.slug;
                trayItem.addEventListener('click', () => {
                  const checkbox = checkboxes.find((entry) => entry.value === item.slug);
                  if (checkbox) checkbox.checked = false;
                  const next = readStored().filter((entry) => entry.slug !== item.slug);
                  writeStored(next);
                  updateSelectionState();
                });
                selectionTrayList.appendChild(trayItem);
              });
            }

            checkboxes.forEach((checkbox) => {
              checkbox.addEventListener('change', updateSelectionState);
            });

            clearButton.addEventListener('click', () => {
              checkboxes.forEach((checkbox) => {
                checkbox.checked = false;
              });
              writeStored([]);
              updateSelectionState();
            });

            applyStoredSelection();
            updateSelectionState();
          })();
        </script>
      <% } %>

      <section class="pagination-row">
        <% if (hasPrev) { %>
          <a class="button ghost" href="/cursos?q=<%= encodeURIComponent(q) %>&category=<%= encodeURIComponent(category) %>&maxHours=<%= encodeURIComponent(maxHours || '') %>&offset=<%= prevOffset %>&limit=<%= limit %><%= selectedCoursesQuery ? '&' + selectedCoursesQuery : '' %>">← Anterior</a>
        <% } else { %>
          <span></span>
        <% } %>
        <% if (items.length === limit) { %>
          <a class="button ghost" href="/cursos?q=<%= encodeURIComponent(q) %>&category=<%= encodeURIComponent(category) %>&maxHours=<%= encodeURIComponent(maxHours || '') %>&offset=<%= nextOffset %>&limit=<%= limit %><%= selectedCoursesQuery ? '&' + selectedCoursesQuery : '' %>">Siguiente →</a>
        <% } %>
      </section>
    </main>
  </body>
</html>
