<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%- include('partials-meta') %>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <%- include('partials-header') %>
    <main class="page home">
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">WakeUp · Formación online</p>
          <h1>Encuentra el curso que encaja con tus necesidades.</h1>
          <p class="lead">
            Explora un catálogo online amplio, filtra con rapidez y prepárate para una experiencia de búsqueda inteligente orientada a necesidades formativas reales.
          </p>
          <div class="hero-badges">
            <% heroBadges.forEach(function(item) { %>
              <span><%= item %></span>
            <% }) %>
          </div>
          <form class="search-form" action="/cursos" method="get">
            <input
              type="text"
              name="q"
              placeholder="Ej.: quiero formarme en contabilidad online"
              value=""
            />
            <button type="submit">Buscar cursos</button>
          </form>
          <% if (searchSuggestions && searchSuggestions.length) { %>
            <div class="hero-quick-searches">
              <span>Búsquedas sugeridas:</span>
              <% searchSuggestions.slice(0, 4).forEach(function(item) { %>
                <a href="/cursos?q=<%= encodeURIComponent(item) %>" class="chip suggestion-chip"><%= item %></a>
              <% }) %>
            </div>
          <% } %>
          <p class="helper-text hero-helper">Encuentra formación por temática, categoría o duración y accede a la ficha de cada curso.</p>
          <div class="hero-actions">
            <a class="button secondary" href="/cursos">Ver catálogo</a>
          </div>
        </div>
      </section>

      <section class="stats-strip">
        <article>
          <strong>+2.282</strong>
          <span>cursos importados</span>
        </article>
        <article>
          <strong>100%</strong>
          <span>formación online</span>
        </article>
        <article>
          <strong>Flexible</strong>
          <span>búsqueda rápida por temática, categoría y horas</span>
        </article>
      </section>

      <section class="benefits-strip">
        <% benefitsStrip.forEach(function(item) { %>
          <article>
            <span><%= item.label %></span>
            <strong><%= item.value %></strong>
          </article>
        <% }) %>
      </section>

      <section class="highlights">
        <% valueProps.forEach(function(item) { %>
          <article>
            <h2><%= item.title %></h2>
            <p><%= item.text %></p>
          </article>
        <% }) %>
      </section>

      <section class="featured-section">
        <div class="section-heading">
          <p class="eyebrow dark">Áreas destacadas</p>
          <h2>Categorías pensadas para encontrar antes la formación adecuada</h2>
        </div>
        <div class="featured-grid">
          <% featuredCategories.forEach(function(item) { %>
            <article class="featured-card">
              <h3><%= item.title %></h3>
              <p><%= item.description %></p>
              <a href="/cursos?category=<%= item.slug %>" class="text-link">Explorar categoría →</a>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="trust-section">
        <div class="section-heading">
          <p class="eyebrow dark">Por qué elegir WakeUp</p>
          <h2>Una oferta formativa pensada para encontrar antes lo que necesitas</h2>
        </div>
        <div class="featured-grid">
          <% trustBlocks.forEach(function(item) { %>
            <article class="featured-card">
              <h3><%= item.title %></h3>
              <p><%= item.text %></p>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="usecases-section">
        <div class="section-heading">
          <p class="eyebrow dark">Casos de uso</p>
          <h2>Qué resuelve esta solución en la práctica</h2>
        </div>
        <div class="review-card">
          <ul>
            <% useCases.forEach(function(item) { %>
              <li><%= item %></li>
            <% }) %>
          </ul>
        </div>
      </section>


      <section class="faq-section">
        <div class="section-heading">
          <p class="eyebrow dark">Preguntas clave</p>
          <h2>Respuestas importantes para entender la solución</h2>
        </div>
        <div class="faq-grid">
          <% faqDemo.forEach(function(item) { %>
            <article class="featured-card">
              <h3><%= item.question %></h3>
              <p><%= item.answer %></p>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="cta-band">
        <div>
          <p class="eyebrow dark">Explora el catálogo</p>
          <h2>Encuentra la formación que mejor encaja con tu equipo o con tus objetivos.</h2>
          <p>Accede al catálogo completo, filtra por categoría o duración y revisa el detalle de cada curso.</p>
        </div>
        <a class="button" href="/cursos">Ver cursos</a>
      </section>
    </main>
  </body>
</html>
