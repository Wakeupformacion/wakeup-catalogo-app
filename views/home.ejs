<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%- include('partials-meta') %>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <%- include('partials-header') %>
    <main class="page home">
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">WakeUp · Formación online</p>
          <h1>Encuentra el curso que encaja con tus necesidades.</h1>
          <p class="lead">
            Explora un catálogo online amplio, filtra con rapidez y prepárate para una experiencia de búsqueda inteligente orientada a necesidades formativas reales.
          </p>
          <div class="hero-badges">
            <% heroBadges.forEach(function(item) { %>
              <span><%= item %></span>
            <% }) %>
          </div>
          <form class="search-form" action="/cursos" method="get">
            <input
              type="text"
              name="q"
              placeholder="Ej.: quiero formarme en contabilidad online"
              value=""
            />
            <button type="submit">Buscar cursos</button>
          </form>
          <% if (searchSuggestions && searchSuggestions.length) { %>
            <div class="hero-quick-searches">
              <span>Pruebas rápidas:</span>
              <% searchSuggestions.slice(0, 4).forEach(function(item) { %>
                <a href="/cursos?q=<%= encodeURIComponent(item) %>" class="chip suggestion-chip"><%= item %></a>
              <% }) %>
            </div>
          <% } %>
          <p class="helper-text hero-helper">Puedes validar búsqueda, navegación por categorías, ficha de curso y acceso directo a la API.</p>
          <div class="hero-actions">
            <a class="button secondary" href="/cursos">Ver catálogo</a>
            <a class="button ghost" href="/estado-demo">Ver estado</a>
            <a class="button ghost" href="/api/courses" target="_blank" rel="noopener noreferrer">Ver API</a>
          </div>
        </div>
      </section>

      <section class="quick-proof-strip">
        <article class="proof-card">
          <strong>Qué puedes probar ahora</strong>
          <p>Buscar por necesidad, filtrar por horas, entrar en una ficha y abrir el detalle oficial del curso.</p>
        </article>
        <article class="proof-card">
          <strong>Qué demuestra esta demo</strong>
          <p>Que ya existe una base válida para catálogo navegable, publicación rápida y evolución hacia buscador inteligente.</p>
        </article>
      </section>

      <section class="stats-strip">
        <article>
          <strong>+2.282</strong>
          <span>cursos importados</span>
        </article>
        <article>
          <strong>100%</strong>
          <span>formación online</span>
        </article>
        <article>
          <strong>IA-ready</strong>
          <span>base preparada para buscador semántico</span>
        </article>
      </section>

      <section class="benefits-strip">
        <% benefitsStrip.forEach(function(item) { %>
          <article>
            <span><%= item.label %></span>
            <strong><%= item.value %></strong>
          </article>
        <% }) %>
      </section>

      <section class="highlights">
        <% valueProps.forEach(function(item) { %>
          <article>
            <h2><%= item.title %></h2>
            <p><%= item.text %></p>
          </article>
        <% }) %>
      </section>

      <section class="featured-section">
        <div class="section-heading">
          <p class="eyebrow dark">Áreas destacadas</p>
          <h2>Categorías pensadas para encontrar antes la formación adecuada</h2>
        </div>
        <div class="featured-grid">
          <% featuredCategories.forEach(function(item) { %>
            <article class="featured-card">
              <h3><%= item.title %></h3>
              <p><%= item.description %></p>
              <a href="/cursos?category=<%= item.slug %>" class="text-link">Explorar categoría →</a>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="trust-section">
        <div class="section-heading">
          <p class="eyebrow dark">Solidez del proyecto</p>
          <h2>Una base pensada para catálogo real, no solo para maqueta</h2>
        </div>
        <div class="featured-grid">
          <% trustBlocks.forEach(function(item) { %>
            <article class="featured-card">
              <h3><%= item.title %></h3>
              <p><%= item.text %></p>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="review-section">
        <div class="section-heading">
          <p class="eyebrow dark">Qué se puede revisar ya</p>
          <h2>Puntos clave que esta demo ya deja claros</h2>
        </div>
        <div class="review-card">
          <ul>
            <% reviewPoints.forEach(function(item) { %>
              <li><%= item %></li>
            <% }) %>
          </ul>
        </div>
      </section>

      <section class="process-section">
        <div class="section-heading">
          <p class="eyebrow dark">Cómo funciona</p>
          <h2>Del Excel a una experiencia de búsqueda más inteligente</h2>
        </div>
        <div class="featured-grid">
          <% processSteps.forEach(function(item) { %>
            <article class="featured-card">
              <h3><%= item.title %></h3>
              <p><%= item.text %></p>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="usecases-section">
        <div class="section-heading">
          <p class="eyebrow dark">Casos de uso</p>
          <h2>Qué resuelve esta solución en la práctica</h2>
        </div>
        <div class="review-card">
          <ul>
            <% useCases.forEach(function(item) { %>
              <li><%= item %></li>
            <% }) %>
          </ul>
        </div>
      </section>

      <section class="signals-section">
        <div class="section-heading">
          <p class="eyebrow dark">Señales de inteligencia</p>
          <h2>Capacidades ya preparadas en el buscador</h2>
        </div>
        <div class="review-card">
          <ul>
            <% intelligenceSignals.forEach(function(item) { %>
              <li><%= item %></li>
            <% }) %>
          </ul>
        </div>
      </section>

      <section class="release-section">
        <div class="section-heading">
          <p class="eyebrow dark">Fases de evolución</p>
          <h2>Cómo puede crecer esta solución</h2>
        </div>
        <div class="featured-grid">
          <% releasePhases.forEach(function(item) { %>
            <article class="featured-card">
              <h3><%= item.title %></h3>
              <p><%= item.text %></p>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="ops-section">
        <div class="section-heading">
          <p class="eyebrow dark">Checklist operativa</p>
          <h2>Qué falta para tenerlo plenamente publicado y conectado</h2>
        </div>
        <div class="review-card">
          <ul>
            <% opsChecklist.forEach(function(item) { %>
              <li><%= item %></li>
            <% }) %>
          </ul>
        </div>
      </section>

      <section class="faq-section">
        <div class="section-heading">
          <p class="eyebrow dark">Preguntas clave</p>
          <h2>Respuestas importantes para entender la solución</h2>
        </div>
        <div class="faq-grid">
          <% faqDemo.forEach(function(item) { %>
            <article class="featured-card">
              <h3><%= item.question %></h3>
              <p><%= item.answer %></p>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="milestones-section">
        <div class="section-heading">
          <p class="eyebrow dark">Siguientes hitos</p>
          <h2>Qué queda para pasar de demo sólida a solución publicada</h2>
        </div>
        <div class="review-card">
          <ul>
            <% demoNextMilestones.forEach(function(item) { %>
              <li><%= item %></li>
            <% }) %>
          </ul>
        </div>
      </section>

      <section class="cta-band">
        <div>
          <p class="eyebrow dark">Próxima evolución</p>
          <h2><%= ctaFooter.title %></h2>
          <p><%= ctaFooter.text %></p>
        </div>
        <a class="button" href="/cursos">Probar el catálogo</a>
      </section>
    </main>
  </body>
</html>
