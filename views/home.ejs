<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%- include('partials-meta') %>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <%- include('partials-header') %>
    <main class="page home">
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">WakeUp · Formación online</p>
          <h1>Encuentra el curso que encaja con tus necesidades.</h1>
          <p class="lead">
            Explora un catálogo online claro, filtra con rapidez y accede a la ficha de cada curso de forma sencilla.
          </p>
          <div class="hero-badges">
            <% heroBadges.forEach(function(item) { %>
              <span><%= item %></span>
            <% }) %>
          </div>
          <form class="search-form" action="/cursos" method="get">
            <input
              type="text"
              name="q"
              placeholder="Ej.: quiero formarme en contabilidad online"
              value=""
            />
            <button type="submit" class="hero-search-button">Buscar cursos</button>
          </form>
          <% if (searchSuggestions && searchSuggestions.length) { %>
            <div class="hero-quick-searches">
              <span>Búsquedas sugeridas:</span>
              <% searchSuggestions.slice(0, 4).forEach(function(item) { %>
                <a href="/cursos?q=<%= encodeURIComponent(item) %>" class="chip suggestion-chip"><%= item %></a>
              <% }) %>
            </div>
          <% } %>
          <p class="helper-text hero-helper">Encuentra formación por temática, categoría o duración y accede a la ficha de cada curso.</p>
          <div class="hero-actions">
            <a class="button secondary" href="/cursos">Ver catálogo</a>
          </div>
        </div>
      </section>

      <% if (allCategories && allCategories.length) { %>
        <section class="all-categories-section">
          <div class="section-heading">
            <p class="eyebrow dark">Todas las temáticas</p>
            <h2>Explora el catálogo por categoría</h2>
          </div>
          <div class="all-categories-grid">
            <% allCategories.forEach(function(item) { %>
              <% const label = String(item.category_label || '').toLowerCase(); %>
              <% let categoryIcon = '📘'; %>
              <% if (label.includes('admin') || label.includes('contabil') || label.includes('finan')) { categoryIcon = '📊'; } %>
              <% else if (label.includes('comercial') || label.includes('venta') || label.includes('cliente')) { categoryIcon = '🤝'; } %>
              <% else if (label.includes('diseño') || label.includes('arte') || label.includes('graf')) { categoryIcon = '🎨'; } %>
              <% else if (label.includes('digital') || label.includes('tic') || label.includes('inform')) { categoryIcon = '💻'; } %>
              <% else if (label.includes('constru') || label.includes('obra') || label.includes('edific')) { categoryIcon = '🏗️'; } %>
              <% else if (label.includes('electric') || label.includes('mec')) { categoryIcon = '⚙️'; } %>
              <% else if (label.includes('agrar') || label.includes('fitosan') || label.includes('alimenta')) { categoryIcon = '🌿'; } %>
              <% else if (label.includes('educ')) { categoryIcon = '🎓'; } %>
              <% else if (label.includes('agencia') || label.includes('viaj')) { categoryIcon = '✈️'; } %>
              <% else if (label.includes('farm')) { categoryIcon = '💊'; } %>
              <% else if (label.includes('energia') || label.includes('renovable')) { categoryIcon = '⚡'; } %>
              <a href="/cursos?category=<%= item.category_normalized %>" class="category-tile">
                <div class="category-tile-icon" aria-hidden="true"><%= categoryIcon %></div>
                <div class="category-tile-content">
                  <span><%= item.category_label %></span>
                  <small><%= item.total %> cursos</small>
                </div>
              </a>
            <% }) %>
          </div>
        </section>
      <% } %>

      <section class="cta-band">
        <div>
          <p class="eyebrow dark">Explora el catálogo</p>
          <h2>Encuentra la formación que mejor encaja con tu equipo o con tus objetivos.</h2>
          <p>Accede al catálogo completo, filtra por categoría o duración y revisa el detalle de cada curso.</p>
        </div>
        <a class="button" href="/cursos">Ver cursos</a>
      </section>
    </main>
  </body>
</html>
